# Path to the runtime SQLite database file.
# Optional: in Docker it defaults to /data/wlhl.sqlite (a persistent volume,
# seeded from database-init.sqlite on first boot). Leave blank to use that
# default, or set an absolute path to point at another WLHL database file.
WLHL_SQLITE_PATH=

# Login credentials. Use strong, unique values.
WLHL_AUTH_USERNAME=admin
WLHL_AUTH_PASSWORD=change-me
